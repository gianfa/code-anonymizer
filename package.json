{
  "name": "code-anonymizer",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "pnpm -r build",
    "build:ext": "pnpm --filter code-anonymizer-vscode build",
    "dev": "pnpm -r dev",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint . && pnpm -r --if-present lint",
    "test": "vitest run",
    "scan:secrets": "gitleaks git . --log-opts='-1'",
    "scan:deps": "osv-scanner scan -L pnpm-lock.yaml",
    "scan": "pnpm scan:deps && pnpm scan:secrets",
    "release": "changeset publish",
    "check:build": "pnpm build && pnpm test && pnpm build:ext"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "tsx": "^4.21.0",
    "vitest": "^3.2.4"
  }
}
