{
  "name": "redactor-monorepo",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "pnpm -r build",
    "build:ext": "pnpm --filter redactor build",
    "dev": "pnpm -r dev",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint . && pnpm -r --if-present lint",
    "test": "vitest run",
    "scan:secrets": "gitleaks git . --log-opts='-1'",
    "scan:deps": "osv-scanner scan -L pnpm-lock.yaml",
    "scan": "pnpm scan:deps && pnpm scan:secrets",
    "release": "changeset publish",
    "check:build": "pnpm build && pnpm test && pnpm build:ext"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vscode/vsce": "3.7.1",
    "eslint": "^10.1.0",
    "tsx": "^4.21.0",
    "vitest": "^4.1.2"
  },
  "version": "1.0.0",
  "description": "A lightweight TypeScript library to quickly anonymize sensitive data in code snippets or logs.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "dependencies": {
    "eslint-scope": "^9.1.2",
    "eslint-visitor-keys": "^5.0.1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "pnpm": {
    "overrides": {
      "brace-expansion@<5.0.5": ">=5.0.5"
    }
  }
}
