{
  "name": "@gianfa/redactor-core",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gianfa/code-anonymizer.git"
  },
  "version": "0.1.2",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "bin": {
    "redactor": "dist/cli.js"
  },
  "files": [
    "dist",
    "data"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "../vscode-ext/node_modules/.bin/tsup src/index.ts src/cli.ts --format cjs --dts --splitting false",
    "dev": "../vscode-ext/node_modules/.bin/tsc -w -p tsconfig.json",
    "typecheck": "../vscode-ext/node_modules/.bin/tsc --noEmit",
    "lint": "../vscode-ext/node_modules/.bin/tsc --noEmit"
  }
}
