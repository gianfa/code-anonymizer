{
  "name": "@redactor/core",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "redactor": "dist/cli.cjs"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm,cjs --dts --splitting false",
    "dev": "tsc -w -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  }
}