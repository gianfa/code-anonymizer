{
  "name": "code-anonymizer-vscode",
  "version": "0.1.0",
  "main": "dist/extension.js",
  "private": true,
  "engines": {
    "vscode": "^1.90.0"
  },
  "activationEvents": [
    "onCommand:code-anonymizer.anonymize"
  ],
  "contributes": {
    "commands": [
      {
        "command": "code-anonymizer.anonymize",
        "title": "Anonymize"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "code-anonymizer.anonymize",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "build": "tsup src/extension.ts --format cjs --external vscode",
    "dev": "tsup src/extension.ts --watch --format cjs --external vscode"
  },
  "dependencies": {
    "@code-anonymizer/core": "workspace:*"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  }
}
