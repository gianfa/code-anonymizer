{
  "name": "redactor",
  "displayName": "RedActor",
  "description": "Anonymize sensitive code snippets before sharing.",
  "version": "0.1.2",
  "author": "Gianfrancesco Angelini",
  "license": "MIT",
  "icon": "assets/icon_min.png",
  "keywords": [
    "anonymize",
    "sanitize",
    "privacy",
    "security",
    "secrets",
    "logs",
    "gdpr",
    "pii"
  ],
  "categories": [
    "Other",
    "Snippets",
    "Linters",
    "Programming Languages"
  ],
  "galleryBanner": {
    "color": "#0b0b0b",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gianfa/code-anonymizer"
  },
  "homepage": "https://github.com/gianfa/code-anonymizer",
  "bugs": {
    "url": "https://github.com/gianfa/code-anonymizer/issues"
  },
  "publisher": "GianfrancescoAngelini",
  "main": "./dist/extension.js",
  "private": true,
  "engines": {
    "vscode": "^1.90.0"
  },
  "activationEvents": [
    "onCommand:redactor.anonymize",
    "onCommand:redactor.diff"
  ],
  "contributes": {
    "commands": [
      {
        "command": "redactor.anonymize",
        "title": "Anonymize Code"
      },
      {
        "command": "redactor.diff",
        "title": "Anonymize Code (Preview Diff)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "redactor.anonymize",
          "group": "navigation"
        },
        {
          "command": "redactor.diff",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "RedActor",
      "properties": {
        "redactor.enableEmails": {
          "type": "boolean",
          "default": true,
          "description": "Detect and replace email addresses."
        },
        "redactor.enableUrls": {
          "type": "boolean",
          "default": true,
          "description": "Detect and replace URLs."
        },
        "redactor.enableIps": {
          "type": "boolean",
          "default": true,
          "description": "Detect and replace IP addresses."
        },
        "redactor.enableSecrets": {
          "type": "boolean",
          "default": true,
          "description": "Detect and replace secrets."
        },
        "redactor.enableNames": {
          "type": "boolean",
          "default": true,
          "description": "Detect and replace human names."
        },
        "redactor.customPatterns": {
          "type": "array",
          "default": [],
          "description": "Custom regex replacement rules.",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "regex": {
                "type": "string"
              },
              "replace": {
                "type": "string"
              }
            },
            "required": [
              "name",
              "regex",
              "replace"
            ]
          }
        },
        "redactor.openInNewTab": {
          "type": "boolean",
          "default": true,
          "description": "Open anonymized output in a new editor tab."
        },
        "redactor.highlight.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable inline highlight of anonymized values."
        },
        "redactor.highlight.color": {
          "type": "string",
          "default": "rgba(0, 255, 0, 0.15)",
          "description": "Background color for anonymized highlights."
        }
      }
    }
  },
  "scripts": {
    "build": "tsup src/extension.ts --format cjs --external vscode && mkdir -p data && cp ../core/data/names.txt data/names.txt",
    "dev": "tsup src/extension.ts --watch --format cjs --external vscode",
    "vscode:prepublish": "pnpm build",
    "typecheck": "pnpm --filter @gianfa/redactor-core build && tsc --noEmit -p tsconfig.json",
    "lint": "tsc --noEmit -p tsconfig.json",
    "package:vsix": "vsce package"
  },
  "devDependencies": {
    "@gianfa/redactor-core": "workspace:*",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "3.7.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}