{
  "name": "@redactor/vscode",
  "version": "0.1.0",
  "main": "dist/extension.js",
  "private": false,
  "engines": {
    "vscode": "^1.90.0"
  },
  "activationEvents": [
    "onCommand:redactor.anonymize",
    "onCommand:redactor.diff"
  ],
  "contributes": {
    "commands": [
      {
        "command": "redactor.anonymize",
        "title": "Anonymize Code"
      },
      {
        "command": "redactor.diff",
        "title": "Anonymize Code (Preview Diff)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "redactor.anonymize",
          "group": "navigation"
        },
        {
          "command": "redactor.diff",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "RedActor",
      "properties": {
        "redActor.enableEmails": {
          "type": "boolean",
          "default": true,
          "description": "Detect and replace email addresses."
        },
        "redActor.enableUrls": {
          "type": "boolean",
          "default": true,
          "description": "Detect and replace URLs."
        },
        "redActor.enableIps": {
          "type": "boolean",
          "default": true,
          "description": "Detect and replace IP addresses."
        },
        "redActor.enableSecrets": {
          "type": "boolean",
          "default": true,
          "description": "Detect and replace secrets."
        },
        "redActor.enableNames": {
          "type": "boolean",
          "default": true,
          "description": "Detect and replace human names."
        },
        "redActor.customPatterns": {
          "type": "array",
          "default": [],
          "description": "Custom regex replacement rules.",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "regex": {
                "type": "string"
              },
              "replace": {
                "type": "string"
              }
            },
            "required": [
              "name",
              "regex",
              "replace"
            ]
          }
        },
        "redActor.openInNewTab": {
          "type": "boolean",
          "default": true,
          "description": "Open anonymized output in a new editor tab."
        },
        "redActor.highlight.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable inline highlight of anonymized values."
        },
        "redActor.highlight.color": {
          "type": "string",
          "default": "rgba(0, 255, 0, 0.15)",
          "description": "Background color for anonymized highlights."
        }
      }
    }
  },
  "scripts": {
    "build": "tsup src/extension.ts --format cjs --external vscode,@redactor/core",
    "dev": "tsup src/extension.ts --watch --format cjs --external vscode",
    "typecheck": "pnpm --filter @redactor/core build && tsc --noEmit -p tsconfig.json",
    "lint": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
     "@redactor/core": "workspace:*"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  },
  "displayName": "RedActor",
  "description": "RedActor: anonymize sensitive code snippets before sharing."
}
